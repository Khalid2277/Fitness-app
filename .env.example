# AlfaNutrition Environment Configuration
# Copy this file to .env and fill in your API keys.

# OpenAI API Key — powers the AI Coach (trainer + nutritionist)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Model — which model to use for chat completions
# Options: gpt-5.3, gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_MODEL=gpt-5.3

# USDA FoodData Central API Key (optional, DEMO_KEY has rate limits)
# Get yours at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=DEMO_KEY
